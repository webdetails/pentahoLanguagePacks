<assembly
  xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 http://maven.apache.org/xsd/assembly-1.1.3.xsd">

  <!--
    Per-locale language pack assembly.
    Activated by the build-language-pack Maven profile (-DlangCode=xx).

    By the time this runs (package phase):
      - All resources-filtered/ templates have been filtered → target/filtered-templates/
      - Locale data has been copied & <TRANSLATE ME> stripped → target/processed-data/${langCode}/
  -->

  <id>langpack</id>

  <!-- finalName and outputDirectory are configured in the POM execution -->
  <baseDirectory>${langpack.name}</baseDirectory>

  <formats>
    <format>zip</format>
  </formats>

  <fileSets>
    <!--
      Maven-filtered templates (from target/filtered-templates/):
      cpk.xml, plugin.xml, plugin.spring.xml, settings.xml,
      dashboards/admin/main.cdfde, version.xml.
    -->
    <fileSet>
      <directory>${project.build.directory}/filtered-templates</directory>
      <outputDirectory>.</outputDirectory>
    </fileSet>

    <!--
      Locale-specific files — declared BEFORE the skeleton so they win
      (assembly plugin is first-writer-wins with overwrite=false by default).
    -->

    <!-- Locale messages; skeleton still contributes messages_en/messages_fr which locale data omits -->
    <fileSet>
      <directory>${data.dir}/${langCode}/resources/lang</directory>
      <outputDirectory>resources/lang</outputDirectory>
    </fileSet>

    <!-- Locale flag image -->
    <fileSet>
      <directory>${data.dir}/${langCode}/resources/img</directory>
      <outputDirectory>static/custom/img</outputDirectory>
      <includes>
        <include>flag.png</include>
      </includes>
    </fileSet>

    <!-- Locale metadata.json (no <TRANSLATE ME>, copied directly from source) -->
    <fileSet>
      <directory>${data.dir}/${langCode}</directory>
      <outputDirectory>data</outputDirectory>
      <includes>
        <include>metadata.json</include>
      </includes>
    </fileSet>

    <!-- Locale-specific translation files (system/ and tomcat/), <TRANSLATE ME> already stripped -->
    <fileSet>
      <directory>${project.build.directory}/processed-data/${langCode}</directory>
      <outputDirectory>data/${langCode}</outputDirectory>
    </fileSet>

    <!--
      Unfiltered plugin skeleton: cpk.spring.xml, endpoints/, static/, resources/, dashboards/admin/main.wcdf.
      All files that were previously duplicated in resources/ now live exclusively in resources-filtered/
      and are included above via target/filtered-templates/.
    -->
    <fileSet>
      <directory>${project.basedir}/src/main/resources</directory>
      <outputDirectory>.</outputDirectory>
    </fileSet>
  </fileSets>

  <!-- CPK/CPF runtime JARs — resolved directly by the assembly plugin -->
  <dependencySets>
    <dependencySet>
      <includes>
        <include>pentaho:cpf-core:jar</include>
        <include>pentaho:cpf-pentaho:jar</include>
        <include>org.pentaho.ctools:cpk-core:jar</include>
        <include>org.pentaho.ctools:cpk-pentaho5:jar</include>
      </includes>
      <useProjectArtifact>false</useProjectArtifact>
      <outputDirectory>lib</outputDirectory>
      <useTransitiveDependencies>false</useTransitiveDependencies>
    </dependencySet>
  </dependencySets>

</assembly>
